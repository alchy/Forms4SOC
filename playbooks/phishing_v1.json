          "title": "Společné údaje",
          "type": "form",
          "note": "Vyplní SOC Analytik",
          "fields": [
            {
              "key": "ticket_id",
              "label": "Ticket ID",
              "type": "text",
              "editable": false,
              "value": null,
              "hint": "Generováno automaticky systémem"
            }
          ]
        },

        {
          "id": "reported_by_person",
          "title": "Hlášeno osobou",
          "type": "form",
          "note": "Vyplní SOC Analytik — přeskoč pokud jde o automatizovanou detekci",
          "condition": "source_type == 'person'",
          "fields": [
            {"key": "reported_at",           "label": "Datum a čas nahlášení",                        "type": "datetime", "editable": true, "is_example": true,  "value": "2025-03-15T09:42"},
            {"key": "reporter_name",         "label": "Jméno oznamovatele",                           "type": "text",     "editable": true, "is_example": true,  "value": "Jan Novák"},
            {"key": "reporter_department",   "label": "Oddělení / organizační jednotka",              "type": "text",     "editable": true, "is_example": true,  "value": "Účetní oddělení"},
            {"key": "reporter_contact",      "label": "Kontakt (e-mail / telefon)",                   "type": "text",     "editable": true, "is_example": true,  "value": "novakj@ans.cz / +420 123 456 789"},
            {"key": "affected_user",         "label": "Postižený uživatel (pokud jiný než oznamovatel)", "type": "text",  "editable": true, "is_example": true,  "value": "(oznamovatel = postižený)"},
            {"key": "affected_asset",        "label": "Postižený asset",                              "type": "text",     "editable": true, "is_example": true,  "value": "PC-NOVAK-01 · mailbox: novakj@ans.cz",
              "hint": "Uveď hostname počítače, IP adresu, název systému nebo mailbox"},
            {"key": "target_type",           "label": "Cíl události",                                 "type": "select",   "editable": true, "is_example": true,  "value": "Uživatel",
              "options": ["Uživatel", "Informační systém", "Kombinace"],
              "option_hints": {"Uživatel": "Útok cílí na konkrétního uživatele nebo skupinu", "Informační systém": "Cílem je konkrétní IS nebo infrastruktura", "Kombinace": "Obojí"}},
            {"key": "description_by_reporter", "label": "Popis události slovy oznamovatele",          "type": "textarea", "editable": true, "is_example": true,  "value": "Přišel podezřelý e-mail s přílohou od neznámého odesílatele."}
          ]
        },

        {
          "id": "automated_detection",
          "title": "Automatizovaná detekce",
          "type": "form",
          "note": "Vyplní SOC Analytik — přeskoč pokud hlásila osoba",
          "condition": "source_type == 'automated'",
          "fields": [
            {"key": "alert_timestamp",      "label": "Datum a čas alertu",                "type": "datetime", "editable": true, "is_example": true, "value": "2025-03-15T09:38"},
            {"key": "detection_tool",       "label": "Identifikace detekčního nástroje",  "type": "text",     "editable": true, "value": null},
            {"key": "alert_id",             "label": "ID alertu / Identifikace pravidla", "type": "text",     "editable": true, "value": null},
            {"key": "affected_asset_auto",  "label": "Postižený asset (hostname, IP, IS)","type": "text",     "editable": true, "value": null},
            {"key": "target_type",          "label": "Cíl události",                      "type": "select",   "editable": true, "value": null,
              "options": ["Uživatel", "Informační systém", "Kombinace"]},
            {"key": "alert_description",    "label": "Popis alertu",                      "type": "textarea", "editable": true, "value": null}
          ]
        },

        {
          "id": "affected_assets",
          "title": "Dotčené assety",
          "type": "assets_table",
          "note": "Vyplní SOC Analytik – doplňuj průběžně při každém rozšíření scope",
          "hint": "Pokud je některý asset součástí kritické infrastruktury → ihned informuj CISO.",
          "columns": ["asset", "asset_type", "critical_infrastructure", "owner", "email", "phone", "discovered_at"],
          "column_labels": {
            "asset": "Asset (hostname, IP, mailbox, IS)",
            "asset_type": "Typ assetu",
            "critical_infrastructure": "Kritická infrastruktura",
            "owner": "Vlastník / odpovědná osoba",
            "email": "E-mail",
            "phone": "Telefon",
            "discovered_at": "Zjištěno při"
          },
          "column_options": {
            "asset_type": ["Endpoint", "Server", "Mailbox", "Informační systém", "Síťový prvek", "Sdílené úložiště", "Jiné"],
            "critical_infrastructure": ["Ano", "Ne"],
            "discovered_at": ["Hlášení", "Triage", "Investigace"]
          },
          "editable": true,
          "rows": []
        }

      ]
    },

    {
      "id": "triage",
      "title": "Triage",
      "type": "checklist",
      "step_groups": [

        {
          "id": "context_artifacts",
          "title": "Ověření kontextu a artefaktů",
          "steps": [
            {"id": "ta_01", "action": "Vyžádej si podezřelý e-mail ve formátu .eml nebo jako forward na dedikovanou SOC schránku", "analyst_note": "E-mail přijat jako .eml", "is_example": true, "done": false},
            {"id": "ta_02", "action": "Zaznamenej odesílatele, předmět a časové razítko e-mailu", "analyst_note": "Od: invoice@podezrely-domena.com · Předmět: „Faktura #2025-112\" · Přijato: 2025-03-15 09:31", "is_example": true, "done": false}
          ]
        },

        {
          "id": "email_analysis",
          "title": "Analýza obsahu e-mailu",
          "steps": [
            {"id": "ea_01", "action": "Zkontroluj obsah e-mailu — identifikuj přítomnost přílohy, hyperlinku nebo pouze textu", "analyst_note": "Příloha: faktura_2025.xlsx · Hyperlink přítomen v těle e-mailu", "is_example": true, "done": false},
            {"id": "ea_02", "action": "Ověř záhlaví e-mailu (SPF, DKIM, DMARC)", "analyst_note": "SPF: fail · DKIM: none · Doména spoofována", "is_example": true, "done": false}
          ]
        },

        {
          "id": "attachment_analysis",
          "title": "E-mail obsahuje přílohu",
          "note": "Přeskoč pokud příloha není přítomna",
          "condition": "has_attachment == true",
          "steps": [
            {"id": "att_01", "action": "Zjisti hash přílohy (MD5 / SHA256) — přílohu přímo neotvírej", "analyst_note": "SHA256: 3a1f2b…", "is_example": true, "done": false},
            {"id": "att_02", "action": "Ověř hash na VirusTotal nebo interním Threat Intelligence zdroji", "analyst_note": "VT: 12/72 detekcí – malicious", "is_example": true, "done": false},
            {"id": "att_03", "action": "Zjisti z AV / EDR, zda byla příloha otevřena, kým a kdy", "analyst_note": "Příloha otevřena uživatelem PC-NOVAK-01 ve 09:38", "is_example": true, "done": false},
            {"id": "att_04", "action": "Vyhledej stejný hash na ostatních endpointech přes AV / EDR — kontaktuj Správce AV/EDR (viz Kontaktní matice)", "analyst_note": "Hash nalezen na PC-SVOBODA-02 a PC-KRAL-05", "is_example": true, "done": false}
          ],
          "hints": [
            "Pokud byla příloha otevřena nebo nalezena na více zařízeních → zaznamenej všechna zasažená zařízení a rozšiř scope.",
            "Hash detekován na TI a příloha otevřena → True Positive, High · Hash na TI, příloha neotvřena → True Positive, Medium · Hash na TI nedetekován → zvaž False Positive"
          ]
        },

        {
          "id": "url_analysis",
          "title": "E-mail obsahuje URL odkaz",
          "note": "Přeskoč pokud URL není přítomna",
          "condition": "has_url == true",
          "steps": [
            {"id": "url_01", "action": "Extrahuj URL z e-mailu — neotevírej odkaz přímo, použij defangovaný formát (např. hxxps://)", "analyst_note": "hxxps://podezrely-domena[.]com/faktura", "is_example": true, "done": false},
            {"id": "url_02", "action": "Ověř URL na VirusTotal / URLScan.io nebo interním TI zdroji", "analyst_note": "Kategorizováno jako phishing", "is_example": true, "done": false},
            {"id": "url_03", "action": "Zkontroluj proxy logy — byl odkaz prokliknut? Kým? Kdy? Kontaktuj Správce Proxy (viz Kontaktní matice)", "analyst_note": "Prokliknutí zaznamenáno 09:39 · uživatel: novakj · PC-NOVAK-01", "is_example": true, "done": false}
          ],
          "hints": [
            "Pokud bylo prokliknutí potvrzeno → rozšiř scope.",
            "URL phishing + prokliknutí potvrzeno → True Positive, High · URL phishing, prokliknutí nepotvrzeno → True Positive, Medium"
          ]
        },

        {
          "id": "bec_analysis",
          "title": "Pouze textový e-mail – BEC / Social Engineering",
          "note": "Přeskoč pokud příloha nebo URL jsou přítomny",
          "condition": "has_attachment == false && has_url == false",
          "steps": [
            {"id": "bec_01", "action": "Zhodnoť povahu žádosti — o co odesílatel žádá. Zkontaktuj postiženého uživatele — byla žádost splněna? Pokud splněna → zjisti rozsah (výše transakce, sdílené údaje, …)", "analyst_note": "Žádost o převod platby na „nový účet dodavatele\". Uživatel žádost nesplnil, nahlásil ihned.", "is_example": true, "done": false}
          ],
          "hints": [
            "Pokud uživatel žádost splnil → kontaktuj CISO (viz Kontaktní matice).",
            "Žádost splněna → True Positive, High/Critical · Žádost nesplněna, SPF fail → True Positive, Low/Medium · Odesílatel legitimní → zvaž False Positive"
          ]
        }

      ],

      "result": {
        "id": "triage_result",
        "title": "Výsledek Triage",
        "fields": [
          {"key": "classification", "label": "Klasifikace události",  "type": "select",   "editable": true, "is_example": true, "value": "True Positive",
            "options": ["True Positive", "False Positive", "Benign True Positive"],
            "option_hints": {"True Positive": "Potvrzený bezpečnostní incident – pokračuj Investigací", "False Positive": "Legitimní aktivita chybně vyhodnocena – přejdi na Uzavření", "Benign True Positive": "Odpovídá detekci, ale není škodlivá (např. pentest) – přejdi na Uzavření"}},
          {"key": "severity",       "label": "Závažnost (Severity)",  "type": "select",   "editable": true, "is_example": true, "value": "high",
            "options": ["critical", "high", "medium", "low"],
            "option_hints": {"critical": "Okamžité ohrožení provozu nebo kritické infrastruktury", "high": "Závažný incident s potvrzeným dopadem", "medium": "Incident s omezeným nebo neprokázaným dopadem", "low": "Nízké riziko, žádný aktuální dopad"}},
          {"key": "justification",  "label": "Odůvodnění",            "type": "textarea", "editable": true, "is_example": true, "value": "Škodlivá příloha otevřena jedním uživatelem, hash nalezen na 2 dalších zařízeních"},
          {"key": "decision",       "label": "Rozhodnutí",            "type": "select",   "editable": true, "is_example": true, "value": "Zahájit Investigaci",
            "options": ["Zahájit Investigaci", "Uzavřít incident"]}
        ],
        "notifications": [
          "True Positive, High → informuj CISO do 1 hodiny · informuj Vlastníka dotčeného systému do 30 minut",
          "True Positive, Critical → informuj CISO a Management ihned · zvaž notifikaci CERT / NÚKIB",
          "False Positive / Benign True Positive → informuj oznamovatele · přejdi na Uzavření incidentu"
        ]
      }
    },

    {
      "id": "investigation",
      "title": "Investigace",
      "type": "checklist",
      "description": "Cíl: Potvrdit rozsah kompromitace, korelovat události napříč zdroji, připravit podklady pro Containment.",
      "step_groups": [
        {
          "id": "investigation_steps",
          "title": "Akce",
          "severity_filter": ["high", "critical"],
          "steps": [
            {"id": "inv_01", "action": "Koreluj události napříč dostupnými zdroji (proxy, EDR, mail gateway, SIEM)", "analyst_note": "Korelace potvrdila aktivitu na 3 zařízeních, 1 s potvrzeným spuštěním přílohy", "is_example": true, "done": false},
            {"id": "inv_02", "action": "Sestav timeline události — od doručení e-mailu po aktuální stav", "analyst_note": "Timeline přiložena k ticketu", "is_example": true, "done": false},
            {"id": "inv_03", "action": "Identifikuj scope — počet postižených uživatelů, zařízení, systémů, dat", "analyst_note": "3 PC · 18 mailboxů · 1 sdílený síťový disk", "is_example": true, "done": false},
            {"id": "inv_04", "action": "Na inbound mail gateway ověř, kolik příjemců e-mail obdrželo — kontaktuj Správce Exchange", "analyst_note": "E-mail doručen 18 uživatelům ve 3 odděleních", "is_example": true, "done": false},
            {"id": "inv_05", "action": "Zhodnoť, zda jde o cílenou nebo plošnou kampaň, zaznamenej seznam postižených mailboxů", "analyst_note": "Plošná kampaň – seznam příjemců přiložen k ticketu", "is_example": true, "done": false},
            {"id": "inv_06", "action": "Ověř, zda došlo k laterálnímu pohybu nebo exfiltraci dat", "analyst_note": "Laterální pohyb nezaznamenán · exfiltrace dat nezjištěna", "is_example": true, "done": false},
            {"id": "inv_07", "action": "Proveď nucenou AV kontrolu postižených zařízení — kontaktuj Správce AV/EDR", "analyst_note": "AV kontrola spuštěna na PC-NOVAK-01, PC-SVOBODA-02, PC-KRAL-05", "is_example": true, "done": false},
            {"id": "inv_08", "action": "Zajisti důkazy (evidence collection) — logy, .eml soubor, hash, screenshoty", "analyst_note": "Uloženo: /evidence/INC-2025-0042/", "is_example": true, "done": false}
          ],
          "hints": [
            "Pokud počet příjemců přesáhne 5 nebo jde o plošnou kampaň → zvaž rozeslání bezpečnostního upozornění (akce v Containment)."
          ]
        }
      ],

      "result": {
        "id": "investigation_result",
        "title": "Výsledek Investigace",
        "fields": [
          {"key": "final_classification", "label": "Finální klasifikace", "type": "select",   "editable": true, "is_example": true, "value": "True Positive",
            "options": ["True Positive", "False Positive", "Benign True Positive"]},
          {"key": "final_severity",       "label": "Finální Severity",    "type": "select",   "editable": true, "is_example": true, "value": "high",
            "options": ["critical", "high", "medium", "low"]},
          {"key": "confirmed_scope",      "label": "Potvrzený rozsah",    "type": "textarea", "editable": true, "is_example": true, "value": "3 zařízení · maliciózní soubor spuštěn na PC-NOVAK-01 · 18 příjemců phishingové kampaně"}
        ],
        "notifications": [
          "Severity High → potvrď notifikaci CISO · informuj Vlastníka dotčeného systému o výsledcích",
          "Severity Critical → zvaž notifikaci CERT / NÚKIB · připrav hlášení pro Management"
        ]
      }
    },

    {
      "id": "containment_remediation",
      "title": "Containment & Remediation",
      "type": "action_table",
      "description": "Zaznamenej u každé akce zodpovědnou roli a aktuální stav. Pokud akce není relevantní, napiš N/A.",
      "columns": ["action", "responsible_role", "cooperation", "status"],
      "column_labels": {"action": "Akce", "responsible_role": "Zodpovědná role", "cooperation": "Součinnost", "status": "Stav"},
      "status_options": ["Provedeno", "Probíhá", "Čeká", "N/A"],
      "editable_columns": ["status"],
      "rows": [
        {"action": "Izolace postižených zařízení od sítě",                    "responsible_role": "SOC Analytický tým",  "cooperation": "Správce AV/EDR · IT Helpdesk", "status": null},
        {"action": "Blokace domény odesílatele na mail serveru",              "responsible_role": "SOC Analytický tým",  "cooperation": "Správce Exchange",             "status": null},
        {"action": "Blokace URL / domény na proxy / firewallu",               "responsible_role": "SOC Analytický tým",  "cooperation": "Správce Proxy",                "status": null},
        {"action": "Blokace hash přílohy v AV / EDR",                         "responsible_role": "SOC Analytický tým",  "cooperation": "Správce AV/EDR",               "status": null},
        {"action": "Vyhledání hashe na ostatních zařízeních přes AV / EDR",   "responsible_role": "SOC Analytický tým",  "cooperation": "Správce AV/EDR",               "status": null},
        {"action": "Reset přihlašovacích údajů postižených uživatelů",        "responsible_role": "IT Helpdesk",          "cooperation": "SOC Analytický tým",           "status": null},
