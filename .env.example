# Forms4SOC - příklad konfigurace
# Zkopíruj tento soubor jako .env a uprav hodnoty

# --- Branding aplikace ---
# APP_NAME=Forms4SOC
# APP_VERSION=0.2.0
# APP_SUBTITLE=SOC Incident Management Portal

# --- JWT ---
# POZOR: V produkci nastav silný náhodný klíč!
# Generace: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=480

# --- Přihlašovací údaje prvního admin účtu ---
# Použijí se pouze při prvním spuštění (pokud databáze neexistuje)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- Cesty (volitelné – lze změnit také v GUI → Nastavení) ---
# DATABASE_PATH=data/forms4soc.db
# DEFAULT_INCIDENTS_DIR=data/events
# DEFAULT_TEMPLATES_DIR=data/workbooks
