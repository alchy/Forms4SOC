# Forms4SOC - příklad konfigurace
# Zkopíruj tento soubor jako .env a uprav hodnoty

# --- Aplikace ---
APP_NAME="Forms4SOC"
DEBUG=false

# --- JWT ---
# POZOR: V produkci nastav silný náhodný klíč (např. openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Auth provider ---
# Možnosti: simple | oauth | ldap
AUTH_PROVIDER=simple

# --- Jednoduchá autentizace (simple provider) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- Cesty ---
PLAYBOOKS_DIR=playbooks
DATABASE_PATH=data/forms4soc.db
